# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, this can be useful so that developers can use the same version.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you are building a library, you should keep it.
#   If you are building an app, it is a must.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is target of version control in applications.
#   If you are building a library, it should be gitignored.
#poetry.lock

# pdm
#   Similar to Poetry and Pipenv, pdm.lock is target of version control in applications.
#pdm.lock
#   pdm build stage cache
.pdm-build/

